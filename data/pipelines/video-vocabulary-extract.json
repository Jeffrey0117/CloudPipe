{
  "id": "video-vocabulary-extract",
  "name": "Video Vocabulary Extract",
  "description": "Process a video URL, extract vocabulary, and generate content appreciation",
  "input": {
    "url": { "type": "string", "required": true, "description": "Video URL (YouTube, Instagram, Bilibili, TikTok)" }
  },
  "steps": [
    {
      "id": "process",
      "tool": "reelscript_process_video",
      "params": { "url": "{{input.url}}" }
    },
    {
      "id": "vocabulary",
      "tool": "reelscript_analyze_vocabulary",
      "params": { "video_id": "{{steps.process.data.video_id}}" }
    },
    {
      "id": "appreciate",
      "tool": "reelscript_appreciate_video",
      "params": { "video_id": "{{steps.process.data.video_id}}" },
      "continueOnError": true
    }
  ]
}
